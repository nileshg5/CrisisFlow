rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow any authenticated user (including anonymous) to read & write
    // to the three collections CrisisFlow uses.
    // For production, tighten these rules with role-based checks.

    match /needs/{needId} {
      allow read, write: if request.auth != null;
    }

    match /volunteers/{volunteerId} {
      allow read, write: if request.auth != null;
    }

    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
  }
}
